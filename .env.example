# Copy this to `.env` and fill in real values. Never commit `.env` itself.

# Supabase: Project Settings > API in your Supabase dashboard
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY   # backend only, full access -- never expose to frontend
SUPABASE_ANON_KEY=YOUR-ANON-KEY                    # safe for frontend, respects RLS policies

# NSE fetch tuning
NSE_POLL_INTERVAL_SECONDS=5
NSE_SYMBOL=NIFTY

# Live data mode (set these on your DEPLOYED backend, e.g. Render):
LIVE_NSE=true
SUPABASE_RELAY=true       # read the latest Supabase snapshot instead of calling NSE per-request
BACKGROUND_POLL=true      # auto-starts an in-process loop on server boot that keeps writing snapshots
                          # -- this is what makes live data show up with zero manual steps

# If/when you get a paid intraday data vendor for the DOS backtest:
# KITE_API_KEY=
# KITE_API_SECRET=
