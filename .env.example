# Copy this to `.env` and fill in real values. Never commit `.env` itself.

# Supabase: Project Settings > API in your Supabase dashboard
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY   # backend only, full access -- never expose to frontend
SUPABASE_ANON_KEY=YOUR-ANON-KEY                    # safe for frontend, respects RLS policies

# NSE fetch tuning
NSE_POLL_INTERVAL_SECONDS=5
NSE_SYMBOL=NIFTY

# If/when you get a paid intraday data vendor for the DOS backtest:
# KITE_API_KEY=
# KITE_API_SECRET=
